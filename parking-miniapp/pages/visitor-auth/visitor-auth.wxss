.container {
  padding: 16px;
  padding-bottom: 100px;
  background: #f7f8fa;
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 16px;
  background: #fff;
  border-radius: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.header-icon {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, #1989fa 0%, #4aa3ff 100%);
  border-radius: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.header-icon image {
  width: 40px;
  height: 40px;
}

.page-title {
  font-size: 20px;
  font-weight: bold;
  color: #323233;
  margin-bottom: 8px;
}

.page-desc {
  font-size: 13px;
  color: #969799;
  text-align: center;
  line-height: 1.6;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
  margin-bottom: 16px;
  display: block;
}

/* 停车场选择器 */
.parking-selector {
  border: 2px dashed #ebedf0;
  border-radius: 12px;
  padding: 20px;
}

.selector-content {
  display: flex;
  align-items: center;
}

.selector-icon {
  width: 20px;
  height: 20px;
  margin-right: 8px;
}

.selector-text {
  flex: 1;
  font-size: 14px;
  color: #969799;
}

.arrow-icon {
  width: 16px;
  height: 16px;
  opacity: 0.3;
}

.selected-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.selected-name {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
  margin-bottom: 4px;
}

.selected-address {
  font-size: 12px;
  color: #969799;
}

/* 表单项 */
.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 14px;
  color: #323233;
  width: 80px;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 14px;
  color: #323233;
}

.form-input::placeholder {
  color: #c8c9cc;
}

.picker-value {
  display: flex;
  align-items: center;
  font-size: 14px;
  color: #323233;
}

/* 备注 */
.remark-input {
  width: 100%;
  height: 80px;
  background: #f7f8fa;
  border-radius: 12px;
  padding: 16px;
  font-size: 14px;
  color: #323233;
  box-sizing: border-box;
}

.remark-input::placeholder {
  color: #c8c9cc;
}

.remark-count {
  display: block;
  text-align: right;
  font-size: 12px;
  color: #969799;
  margin-top: 8px;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
}

.generate-btn {
  width: 100%;
  height: 48px;
  background: #1989fa;
  color: #fff;
  font-size: 16px;
  font-weight: 500;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.generate-btn.disabled {
  background: #c8c9cc;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 80%;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #f5f5f5;
}

.modal-title {
  font-size: 18px;
  font-weight: bold;
  color: #323233;
}

.close-btn {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
}

.close-icon {
  font-size: 20px;
  color: #969799;
  line-height: 1;
}

.qr-canvas {
  width: 200px;
  height: 200px;
  background: #f7f8fa;
  border-radius: 8px;
}

.modal-body {
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-code {
  font-size: 32px;
  font-weight: bold;
  color: #1989fa;
  letter-spacing: 8px;
  margin-bottom: 16px;
}

.code-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  margin-bottom: 20px;
}

.info-item {
  font-size: 13px;
  color: #969799;
}

.qr-code {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.qr-code image {
  width: 150px;
  height: 150px;
  background: #f7f8fa;
}

.qr-code text {
  font-size: 12px;
  color: #969799;
}

.modal-footer {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-top: 1px solid #f5f5f5;
}

.share-btn,
.save-btn {
  flex: 1;
  height: 44px;
  border-radius: 22px;
  font-size: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-btn {
  background: #07c160;
  color: #fff;
}

.save-btn {
  background: #f7f8fa;
  color: #323233;
}