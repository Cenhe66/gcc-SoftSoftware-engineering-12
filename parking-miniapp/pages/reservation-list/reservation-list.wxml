<view class="container">
  <!-- 标签切换 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{currentTab === 'upcoming' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="upcoming"
    >
      即将开始
      <text class="badge" wx:if="{{upcomingCount > 0}}">{{upcomingCount}}</text>
    </view>
    <view 
      class="tab-item {{currentTab === 'ongoing' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="ongoing"
    >
      进行中
      <text class="badge" wx:if="{{ongoingCount > 0}}">{{ongoingCount}}</text>
    </view>
    <view 
      class="tab-item {{currentTab === 'history' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="history"
    >
      历史记录
    </view>
  </view>

  <!-- 预约列表 -->
  <view class="reservation-list">
    <view 
      class="reservation-card"
      wx:for="{{reservationList}}"
      wx:key="id"
    >
      <!-- 状态标签 -->
      <view class="status-tag {{item.status}}">
        {{item.statusText}}
      </view>

      <!-- 停车场信息 -->
      <view class="parking-info">
        <text class="parking-name">{{item.parkingName}}</text>
        <text class="space-code" wx:if="{{item.spaceCode}}">车位：{{item.spaceCode}}</text>
      </view>

      <!-- 时间信息 -->
      <view class="time-info">
        <view class="time-row">
          <view class="time-icon start"></view>
          <view class="time-detail">
            <text class="time-date">{{item.startDate}}</text>
            <text class="time-clock">{{item.startTime}}</text>
          </view>
        </view>
        <view class="time-line"></view>
        <view class="time-row">
          <view class="time-icon end"></view>
          <view class="time-detail">
            <text class="time-date">{{item.endDate}}</text>
            <text class="time-clock">{{item.endTime}}</text>
          </view>
        </view>
      </view>

      <!-- 车辆信息 -->
      <view class="vehicle-info">
        <view class="info-item">
          <text class="info-label">车牌</text>
          <text class="info-value">{{item.plateNumber}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">时长</text>
          <text class="info-value">{{item.duration}}小时</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-bar">
        <view class="cost-info" wx:if="{{item.status === 'completed' || item.status === 'cancelled' || item.status === 'unpaid'}}">
          <text class="cost-label">费用</text>
          <text class="cost-value">¥{{item.reserveFee || item.amount || '0.00'}}</text>
        </view>
        <!-- 待支付停车费状态显示停车费 -->
        <view class="cost-info" wx:if="{{item.status === 'pending_payment'}}">
          <text class="cost-label">停车费</text>
          <text class="cost-value">¥{{item.parkingFee || item.amount || '0.00'}}</text>
        </view>
        <!-- 待支付状态显示支付倒计时 -->
        <view class="pay-countdown" wx:if="{{item.status === 'unpaid' && item.payCountdownText}}">
          <text class="countdown-icon">⏱</text>
          <text class="countdown-label">支付倒计时</text>
          <text class="countdown-value {{item.isExpired ? 'expired' : 'warning'}}">{{item.payCountdownText}}</text>
        </view>
        <!-- 使用中状态显示预估费用 -->
        <view class="cost-info" wx:if="{{item.status === 'ongoing'}}">
          <text class="cost-label">预约费</text>
          <text class="cost-value">¥{{item.reserveFee || '0.00'}}</text>
        </view>
        <view class="duration-info" wx:if="{{item.status === 'ongoing' && item.parkedDuration}}">
          <text class="duration-label">已停</text>
          <text class="duration-value">{{item.parkedDuration}}</text>
        </view>
        <view class="estimated-fee" wx:if="{{item.status === 'ongoing' && item.estimatedFee}}">
          <text class="fee-label">预估</text>
          <text class="fee-value">¥{{item.estimatedFee}}</text>
        </view>
        <!-- 待使用状态显示预约时长 -->
        <view class="duration-info" wx:if="{{item.status === 'upcoming'}}">
          <text class="duration-label">预约</text>
          <text class="duration-value">{{item.durationText}}</text>
        </view>
        <view class="countdown" wx:if="{{item.status === 'upcoming' && item.countdown}}">
          <text class="countdown-label">距开始</text>
          <text class="countdown-value">{{item.countdown}}</text>
        </view>
        <view class="action-btns">
          <!-- 待支付状态：去支付按钮 -->
          <button 
            class="btn pay {{item.isExpired ? 'disabled' : ''}}" 
            wx:if="{{item.status === 'unpaid' && !item.isExpired}}"
            bindtap="goToPayReservation"
            data-item="{{item}}"
          >去支付</button>
          <button 
            class="btn disabled" 
            wx:if="{{item.status === 'unpaid' && item.isExpired}}"
            disabled
          >已超时</button>
          <button 
            class="btn cancel" 
            wx:if="{{item.status === 'unpaid' && !item.isExpired}}"
            bindtap="cancelReservation"
            data-id="{{item.id}}"
          >取消</button>
          <!-- 待使用状态：入场按钮 -->
          <button 
            class="btn pay" 
            wx:if="{{item.status === 'upcoming'}}"
            bindtap="enterParking"
            data-item="{{item}}"
          >入场</button>
          <button 
            class="btn cancel" 
            wx:if="{{item.status === 'upcoming'}}"
            bindtap="cancelReservation"
            data-id="{{item.id}}"
          >取消预约</button>
          <button 
            class="btn navigate" 
            wx:if="{{item.status === 'upcoming' || item.status === 'ongoing'}}"
            bindtap="navigateToParking"
            data-item="{{item}}"
          >导航前往</button>
          <!-- 使用中状态：离场按钮 -->
          <button 
            class="btn pay" 
            wx:if="{{item.status === 'ongoing'}}"
            bindtap="exitParking"
            data-item="{{item}}"
          >离场缴费</button>
          <!-- 待支付停车费状态：支付按钮 -->
          <button 
            class="btn pay" 
            wx:if="{{item.status === 'pending_payment'}}"
            bindtap="goToPayParkingFee"
            data-item="{{item}}"
          >支付停车费</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="load-more" wx:if="{{!hasMore && reservationList.length > 0}}">
    <text>没有更多了</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && reservationList.length === 0}}">
    <image src="/static/icons/空状态图标.png" mode="aspectFit"></image>
    <text>{{emptyText}}</text>
    <button class="reserve-btn" bindtap="goToReserve">去预约</button>
  </view>
</view>
