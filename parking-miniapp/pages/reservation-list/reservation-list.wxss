.container {
  padding-bottom: 32px;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 16px;
  border-bottom: 1px solid #f5f5f5;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16px 0;
  font-size: 14px;
  color: #969799;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active {
  color: #1989fa;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 24px;
  height: 3px;
  background: #1989fa;
  border-radius: 2px;
}

.badge {
  display: inline-block;
  min-width: 16px;
  height: 16px;
  background: #ee0a24;
  color: #fff;
  font-size: 10px;
  border-radius: 8px;
  padding: 0 4px;
  margin-left: 4px;
  line-height: 16px;
}

/* 预约列表 */
.reservation-list {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.reservation-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  position: relative;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

/* 状态标签 */
.status-tag {
  position: absolute;
  top: 16px;
  right: 16px;
  font-size: 12px;
  padding: 4px 12px;
  border-radius: 12px;
}

.status-tag.upcoming {
  color: #1989fa;
  background: rgba(25, 137, 250, 0.1);
}

.status-tag.ongoing {
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.status-tag.unpaid {
  color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
}

.status-tag.completed {
  color: #969799;
  background: #f5f5f5;
}

.status-tag.cancelled {
  color: #969799;
  background: #f5f5f5;
}

.status-tag.expired {
  color: #ff976a;
  background: rgba(255, 151, 106, 0.1);
}

/* 停车场信息 */
.parking-info {
  margin-bottom: 16px;
  padding-right: 80px;
}

.parking-name {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
  margin-bottom: 4px;
  display: block;
}

.space-code {
  font-size: 13px;
  color: #969799;
}

/* 时间信息 */
.time-info {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 16px;
  padding: 12px;
  background: #f7f8fa;
  border-radius: 8px;
}

.time-row {
  display: flex;
  align-items: center;
}

.time-icon {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  margin-right: 12px;
}

.time-icon.start {
  background: #07c160;
}

.time-icon.end {
  background: #ee0a24;
}

.time-line {
  width: 1px;
  height: 20px;
  background: #ebedf0;
  margin-left: 4px;
}

.time-detail {
  display: flex;
  align-items: center;
  gap: 8px;
}

.time-date {
  font-size: 13px;
  color: #323233;
}

.time-clock {
  font-size: 13px;
  color: #969799;
}

/* 车辆信息 */
.vehicle-info {
  display: flex;
  gap: 24px;
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid #f5f5f5;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8px;
}

.info-label {
  font-size: 12px;
  color: #969799;
}

.info-value {
  font-size: 13px;
  color: #323233;
  font-weight: 500;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cost-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.cost-label {
  font-size: 12px;
  color: #969799;
}

.cost-value {
  font-size: 18px;
  font-weight: bold;
  color: #ff976a;
}

.countdown {
  display: flex;
  align-items: center;
  gap: 8px;
}

.countdown-label {
  font-size: 12px;
  color: #969799;
}

.countdown-value {
  font-size: 14px;
  color: #1989fa;
  font-weight: 500;
}

/* 已停时长 */
.duration-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.duration-label {
  font-size: 12px;
  color: #969799;
}

.duration-value {
  font-size: 14px;
  color: #07c160;
  font-weight: 500;
}

/* 预估费用 */
.estimated-fee {
  display: flex;
  align-items: center;
  gap: 8px;
}

.fee-label {
  font-size: 12px;
  color: #969799;
}

.fee-value {
  font-size: 14px;
  color: #ff976a;
  font-weight: 500;
}

.action-btns {
  display: flex;
  gap: 8px;
}

.btn {
  padding: 8px 16px;
  border-radius: 16px;
  font-size: 13px;
  border: none;
}

.btn.cancel {
  background: #f7f8fa;
  color: #969799;
}

.btn.navigate {
  background: rgba(25, 137, 250, 0.1);
  color: #1989fa;
}

.btn.pay {
  background: #1989fa;
  color: #fff;
}

.btn.disabled {
  background: #ebedf0;
  color: #c8c9cc;
}

/* 支付倒计时 */
.pay-countdown {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  background: rgba(255, 107, 107, 0.08);
  border-radius: 8px;
  margin-right: 8px;
}

.pay-countdown .countdown-icon {
  font-size: 14px;
}

.pay-countdown .countdown-label {
  font-size: 12px;
  color: #969799;
}

.pay-countdown .countdown-value {
  font-size: 16px;
  font-weight: bold;
}

.pay-countdown .countdown-value.warning {
  color: #ff6b6b;
}

.pay-countdown .countdown-value.expired {
  color: #c8c9cc;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16px;
}

.load-more text {
  font-size: 12px;
  color: #969799;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 16px;
}

.empty-state image {
  width: 100px;
  height: 100px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-state text {
  font-size: 14px;
  color: #969799;
  margin-bottom: 24px;
}

.reserve-btn {
  width: 160px;
  height: 44px;
  background: #1989fa;
  color: #fff;
  font-size: 16px;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
}
