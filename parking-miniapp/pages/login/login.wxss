.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1989fa 0%, #f7f8fa 40%);
  padding: 40px 32px;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48px;
}

.logo {
  width: 100px;
  height: 100px;
  background: #fff;
  border-radius: 20px;
  margin-bottom: 16px;
}

.app-name {
  font-size: 24px;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8px;
}

.app-slogan {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}

.login-form {
  background: #fff;
  border-radius: 16px;
  padding: 32px 24px;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
}

.input-group {
  margin-bottom: 24px;
}

.input-label {
  display: block;
  font-size: 14px;
  color: #323233;
  margin-bottom: 8px;
  font-weight: 500;
}

.input-field {
  width: 100%;
  height: 48px;
  background: #f7f8fa;
  border-radius: 8px;
  padding: 0 16px;
  font-size: 16px;
  color: #323233;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: #969799;
}

.verify-group {
  display: flex;
  align-items: center;
}

.verify-input {
  flex: 1;
  margin-right: 12px;
}

.verify-btn {
  width: 120px;
  height: 48px;
  background: #1989fa;
  color: #fff;
  font-size: 14px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.verify-btn.disabled {
  background: #c8c9cc;
}

.login-btn {
  width: 100%;
  height: 48px;
  background: #1989fa;
  color: #fff;
  font-size: 16px;
  font-weight: 500;
  border-radius: 24px;
  margin-top: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn.disabled {
  background: #c8c9cc;
}

.divider {
  display: flex;
  align-items: center;
  margin: 24px 0;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #ebedf0;
}

.divider-text {
  padding: 0 16px;
  font-size: 12px;
  color: #969799;
}

.wechat-btn {
  width: 100%;
  height: 48px;
  background: #07c160;
  color: #fff;
  font-size: 16px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon {
  width: 24px;
  height: 24px;
  margin-right: 8px;
}

.login-footer {
  margin-top: 32px;
}

.agreement {
  display: flex;
  align-items: flex-start;
}

.agreement-text {
  font-size: 12px;
  color: #969799;
  line-height: 1.6;
  margin-left: 8px;
}

.link {
  color: #1989fa;
}
