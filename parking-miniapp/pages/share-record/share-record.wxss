.container {
  padding: 16px;
  padding-bottom: 32px;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: linear-gradient(135deg, #07c160 0%, #4ad975 100%);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 16px;
  color: #fff;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 4px;
}

.stat-label {
  font-size: 12px;
  opacity: 0.9;
}

.stat-divider {
  width: 1px;
  height: 40px;
  background: rgba(255, 255, 255, 0.3);
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
}

.filter-tabs {
  display: flex;
  gap: 8px;
}

.filter-tab {
  padding: 6px 16px;
  background: #f7f8fa;
  border-radius: 16px;
  font-size: 13px;
  color: #969799;
}

.filter-tab.active {
  background: #1989fa;
  color: #fff;
}

/* 共享列表 */
.share-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.share-card {
  background: #f7f8fa;
  border-radius: 12px;
  padding: 16px;
  position: relative;
}

/* 状态标签 */
.status-tag {
  position: absolute;
  top: 16px;
  right: 16px;
  font-size: 12px;
  padding: 4px 12px;
  border-radius: 12px;
}

.status-tag.active {
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.status-tag.paused {
  color: #ff976a;
  background: rgba(255, 151, 106, 0.1);
}

.status-tag.ended {
  color: #969799;
  background: #ebedf0;
}

/* 停车场信息 */
.parking-info {
  margin-bottom: 12px;
  padding-right: 80px;
}

.parking-name {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
  margin-bottom: 4px;
  display: block;
}

.space-code {
  font-size: 13px;
  color: #969799;
}

/* 时间信息 */
.time-info {
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #ebedf0;
}

.time-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6px;
}

.time-row:last-child {
  margin-bottom: 0;
}

.time-label {
  font-size: 12px;
  color: #969799;
}

.time-value {
  font-size: 13px;
  color: #323233;
}

/* 价格信息 */
.price-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16px;
}

.price-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.price-item.earnings {
  align-items: flex-end;
}

.price-label {
  font-size: 11px;
  color: #969799;
  margin-bottom: 4px;
}

.price-value {
  font-size: 14px;
  color: #323233;
  font-weight: 500;
}

.price-value.highlight {
  font-size: 18px;
  color: #ff976a;
  font-weight: bold;
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 12px;
  padding-top: 12px;
  border-top: 1px solid #ebedf0;
}

.btn {
  flex: 1;
  height: 36px;
  border-radius: 18px;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn.pause {
  background: rgba(255, 151, 106, 0.1);
  color: #ff976a;
}

.btn.resume {
  background: rgba(25, 137, 250, 0.1);
  color: #1989fa;
}

.btn.stop {
  background: rgba(238, 10, 36, 0.1);
  color: #ee0a24;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16px;
}

.load-more text {
  font-size: 12px;
  color: #969799;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 16px;
}

.empty-state image {
  width: 80px;
  height: 80px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-state text {
  font-size: 14px;
  color: #969799;
  margin-bottom: 24px;
}

.publish-btn {
  width: 160px;
  height: 44px;
  background: #07c160;
  color: #fff;
  font-size: 16px;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
}