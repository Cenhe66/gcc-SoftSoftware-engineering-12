.container {
  padding: 16px;
  padding-bottom: 32px;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 16px;
}

.search-input {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24px;
  padding: 12px 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.search-icon {
  width: 20px;
  height: 20px;
  margin-right: 8px;
  opacity: 0.5;
}

.search-placeholder {
  font-size: 14px;
  color: #969799;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-between;
  background: #fff;
  border-radius: 12px;
  padding: 20px 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.action-icon image {
  width: 28px;
  height: 28px;
}

.action-icon.reservation {
  background: rgba(25, 137, 250, 0.1);
}

.action-icon.share {
  background: rgba(7, 193, 96, 0.1);
}

.action-icon.move-car {
  background: rgba(255, 151, 106, 0.1);
}

.action-icon.ar {
  background: rgba(238, 10, 36, 0.1);
}

.action-text {
  font-size: 12px;
  color: #323233;
}

/* 区块标题 */
.section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
}

.location {
  display: flex;
  align-items: center;
}

.location-icon {
  width: 16px;
  height: 16px;
  margin-right: 4px;
}

.location-text {
  font-size: 12px;
  color: #969799;
}

/* 停车场卡片 */
.parking-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.parking-card {
  display: flex;
  justify-content: space-between;
  padding: 16px;
  background: #f7f8fa;
  border-radius: 12px;
}

.parking-info {
  flex: 1;
  margin-right: 12px;
  min-width: 0;
  overflow: hidden;
}

.parking-name {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
  margin-bottom: 6px;
  display: block;
}

.parking-meta {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.parking-address {
  font-size: 12px;
  color: #969799;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.parking-distance {
  font-size: 12px;
  color: #1989fa;
  margin-left: 8px;
  flex-shrink: 0;
}

.parking-tags {
  display: flex;
  gap: 8px;
}

.parking-tags .tag {
  font-size: 10px;
  color: #1989fa;
  background: rgba(25, 137, 250, 0.1);
  padding: 2px 8px;
  border-radius: 4px;
}

.parking-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  flex-shrink: 0;
  min-width: 80px;
}

.space-count {
  display: flex;
  align-items: baseline;
  margin-bottom: 4px;
  white-space: nowrap;
}

.count-free {
  font-size: 24px;
  font-weight: bold;
  color: #07c160;
}

.count-total {
  font-size: 14px;
  color: #969799;
}

.status-text {
  font-size: 10px;
  color: #969799;
  margin-bottom: 8px;
  white-space: nowrap;
}

.price-info {
  display: flex;
  align-items: baseline;
  white-space: nowrap;
}

.price {
  font-size: 16px;
  font-weight: bold;
  color: #ff976a;
}

.price-unit {
  font-size: 10px;
  color: #969799;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16px;
}

.load-more text {
  font-size: 12px;
  color: #969799;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px;
}

.empty-state image {
  width: 80px;
  height: 80px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-state text {
  font-size: 14px;
  color: #969799;
}
