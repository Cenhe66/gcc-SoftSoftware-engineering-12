.container {
  padding: 16px;
  padding-bottom: 32px;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #1989fa 0%, #4aa3ff 100%);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 16px;
  color: #fff;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 24px;
}

.user-avatar {
  width: 64px;
  height: 64px;
  border-radius: 32px;
  border: 3px solid rgba(255, 255, 255, 0.3);
  margin-right: 16px;
  background: #fff;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 20px;
  font-weight: bold;
  margin-bottom: 4px;
}

.user-phone {
  font-size: 14px;
  opacity: 0.8;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 16px;
  border-top: 1px solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 4px;
}

.stat-label {
  font-size: 12px;
  opacity: 0.8;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
  margin-bottom: 16px;
}

/* 钱包卡片 */
.wallet-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background: linear-gradient(135deg, #ff976a 0%, #ffba8a 100%);
  border-radius: 12px;
  color: #fff;
}

.wallet-item {
  display: flex;
  flex-direction: column;
}

.wallet-label {
  font-size: 12px;
  opacity: 0.9;
  margin-bottom: 4px;
}

.wallet-value {
  font-size: 24px;
  font-weight: bold;
}

.wallet-arrow image {
  width: 20px;
  height: 20px;
  opacity: 0.8;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.menu-icon image {
  width: 18px;
  height: 18px;
}

.menu-text {
  flex: 1;
  font-size: 14px;
  color: #323233;
}

.menu-arrow {
  width: 16px;
  height: 16px;
  opacity: 0.3;
}

/* 退出登录 */
.logout-section {
  margin-top: 8px;
}

.logout-btn {
  width: 100%;
  height: 48px;
  background: #fff;
  color: #ee0a24;
  font-size: 16px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

/* 登录按钮 */
.login-section {
  margin-top: 8px;
}

.login-btn {
  width: 100%;
  height: 48px;
  background: #1989fa;
  color: #fff;
  font-size: 16px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}
