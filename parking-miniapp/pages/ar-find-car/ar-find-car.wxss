.container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

/* 相机 */
.camera {
  width: 100%;
  height: 100%;
}

/* AR覆盖层 */
.ar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

/* 方向箭头 */
.direction-arrow {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80px;
  height: 80px;
  transition: transform 0.3s ease;
}

.direction-arrow image {
  width: 100%;
  height: 100%;
}

/* 距离信息 */
.distance-info {
  position: absolute;
  top: 55%;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(0, 0, 0, 0.6);
  padding: 12px 24px;
  border-radius: 24px;
}

.distance-value {
  font-size: 32px;
  font-weight: bold;
  color: #fff;
}

.distance-label {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.8);
}

/* 车位标记 */
.space-marker {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: bounce 1s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.marker-icon {
  width: 40px;
  height: 40px;
}

.marker-icon image {
  width: 100%;
  height: 100%;
}

.marker-label {
  font-size: 14px;
  color: #fff;
  background: rgba(25, 137, 250, 0.9);
  padding: 4px 12px;
  border-radius: 12px;
  margin-top: 4px;
}

/* 顶部栏 */
.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 44px 16px 16px;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.5), transparent);
}

.info-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12px;
  padding: 12px 16px;
}

.parking-name {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
  display: block;
  margin-bottom: 4px;
}

.space-code {
  font-size: 13px;
  color: #969799;
}

.close-btn {
  width: 40px;
  height: 40px;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-btn image {
  width: 20px;
  height: 20px;
}

/* 底部栏 */
.bottom-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
}

.control-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16px;
  padding: 16px;
}

.floor-selector {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-bottom: 12px;
}

.floor-item {
  padding: 8px 20px;
  background: #f7f8fa;
  border-radius: 16px;
  font-size: 14px;
  color: #969799;
}

.floor-item.active {
  background: #1989fa;
  color: #fff;
}

.hint-text {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.hint-text image {
  width: 16px;
  height: 16px;
}

.hint-text text {
  font-size: 13px;
  color: #969799;
}

/* 权限提示 */
.permission-tip {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tip-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 16px;
  padding: 32px;
  margin: 32px;
}

.tip-content image {
  width: 64px;
  height: 64px;
  margin-bottom: 16px;
}

.tip-content text {
  font-size: 14px;
  color: #323233;
  margin-bottom: 24px;
  text-align: center;
}

.auth-btn {
  width: 160px;
  height: 44px;
  background: #1989fa;
  color: #fff;
  font-size: 16px;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
}