.container {
  padding: 16px;
  padding-bottom: 100px;
  background: #f7f8fa;
  min-height: 100vh;
}

/* 结果头部 */
.result-header {
  border-radius: 16px;
  padding: 32px;
  margin-bottom: 16px;
  text-align: center;
  color: #fff;
}

.result-header.normal {
  background: linear-gradient(135deg, #07c160 0%, #4ad975 100%);
}

.result-header.abnormal {
  background: linear-gradient(135deg, #ff976a 0%, #ffba8a 100%);
}

.status-icon {
  width: 64px;
  height: 64px;
  margin: 0 auto 16px;
}

.status-icon image {
  width: 100%;
  height: 100%;
}

.status-title {
  font-size: 24px;
  font-weight: bold;
  display: block;
  margin-bottom: 8px;
}

.status-desc {
  font-size: 14px;
  opacity: 0.9;
  display: block;
  margin-bottom: 16px;
}

.check-time {
  font-size: 12px;
  opacity: 0.8;
}

/* 车辆卡片 */
.vehicle-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
  text-align: center;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.vehicle-plate {
  font-size: 20px;
  font-weight: bold;
  color: #323233;
  display: block;
  margin-bottom: 4px;
}

.vehicle-label {
  font-size: 12px;
  color: #969799;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
  margin-bottom: 16px;
  display: block;
}

/* 详情列表 */
.detail-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background: #f7f8fa;
  border-radius: 12px;
  border-left: 4px solid #07c160;
}

.detail-item.abnormal {
  border-left-color: #ff976a;
  background: rgba(255, 151, 106, 0.05);
}

.item-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.item-icon {
  width: 32px;
  height: 32px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-icon.normal {
  background: rgba(7, 193, 96, 0.1);
}

.item-icon.abnormal {
  background: rgba(255, 151, 106, 0.1);
}

.item-icon image {
  width: 16px;
  height: 16px;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.item-name {
  font-size: 14px;
  color: #323233;
  font-weight: 500;
}

.item-value {
  font-size: 12px;
  color: #969799;
}

.item-status {
  font-size: 12px;
  padding: 4px 12px;
  border-radius: 12px;
}

.item-status.normal {
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.item-status.abnormal {
  color: #ff976a;
  background: rgba(255, 151, 106, 0.1);
}

/* 建议列表 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px;
  background: rgba(255, 151, 106, 0.05);
  border-radius: 12px;
}

.suggestion-dot {
  width: 8px;
  height: 8px;
  background: #ff976a;
  border-radius: 50%;
  margin-top: 6px;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 14px;
  color: #323233;
  line-height: 1.6;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 12px;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
}

.btn {
  flex: 1;
  height: 48px;
  border-radius: 24px;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn.secondary {
  background: #f7f8fa;
  color: #323233;
}

.btn.primary {
  background: #07c160;
  color: #fff;
}