.container {
  padding: 16px;
  padding-bottom: 100px;
  background: #f7f8fa;
  min-height: 100vh;
}

/* 金额卡片 */
.amount-card {
  background: linear-gradient(135deg, #1989fa 0%, #4aa3ff 100%);
  border-radius: 16px;
  padding: 32px;
  margin-bottom: 16px;
  text-align: center;
  color: #fff;
}

.amount-label {
  font-size: 14px;
  opacity: 0.9;
  display: block;
  margin-bottom: 12px;
}

.amount-value {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  margin-bottom: 8px;
}

.currency {
  font-size: 24px;
  margin-top: 8px;
}

.amount {
  font-size: 56px;
  font-weight: bold;
}

.amount-desc {
  font-size: 14px;
  opacity: 0.8;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #323233;
  margin-bottom: 16px;
  display: block;
}

/* 详情列表 */
.detail-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-label {
  font-size: 14px;
  color: #969799;
}

.item-value {
  font-size: 14px;
  color: #323233;
}

.item-value.order-no {
  font-size: 12px;
  color: #969799;
}

/* 费用列表 */
.cost-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cost-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cost-item.total {
  margin-top: 4px;
}

.cost-label {
  font-size: 14px;
  color: #969799;
}

.cost-value {
  font-size: 14px;
  color: #323233;
}

.cost-value.discount {
  color: #07c160;
}

.cost-item.total .cost-label {
  font-size: 15px;
  color: #323233;
  font-weight: 500;
}

.cost-item.total .cost-value {
  font-size: 18px;
  font-weight: bold;
  color: #ff976a;
}

.divider {
  height: 1px;
  background: #f5f5f5;
  margin: 4px 0;
}

/* 支付方式 */
.pay-methods {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.pay-method {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background: #f7f8fa;
  border-radius: 12px;
  border: 2px solid transparent;
}

.pay-method.active {
  background: rgba(25, 137, 250, 0.05);
  border-color: #1989fa;
}

.method-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.method-icon {
  width: 40px;
  height: 40px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.method-icon.wechat {
  background: rgba(7, 193, 96, 0.1);
}

.method-icon.balance {
  background: rgba(255, 151, 106, 0.1);
}

.method-icon image {
  width: 24px;
  height: 24px;
}

.method-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.method-name {
  font-size: 15px;
  color: #323233;
  font-weight: 500;
}

.method-desc {
  font-size: 12px;
  color: #969799;
}

.method-check {
  width: 20px;
  height: 20px;
}

.method-check image {
  width: 100%;
  height: 100%;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
}

.pay-info {
  display: flex;
  align-items: baseline;
}

.pay-label {
  font-size: 14px;
  color: #969799;
  margin-right: 4px;
}

.pay-amount {
  font-size: 24px;
  font-weight: bold;
  color: #ff976a;
}

.pay-btn {
  width: 140px;
  height: 48px;
  background: #07c160;
  color: #fff;
  font-size: 16px;
  font-weight: 500;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}